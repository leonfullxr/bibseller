<mxfile host="app.diagrams.net" agent="bibseller-docs" version="24.7.8">
  <diagram id="onboard" name="Seller onboarding lifecycle">
    <mxGraphModel dx="1700" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Seller onboarding lifecycle (Stripe Connect Express, D34) - status cached in seller_accounts, written only by the account.updated webhook" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#26221c;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Payment availability is DERIVED at read time: seller active AND race platform_sale AND listings.payment_enabled - a restricted account instantly hides payment everywhere, no sweep job. KYC/identity documents live at Stripe, never on our infrastructure." style="text;html=1;fontSize=12;fontColor=#79736b;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="none" value="none&#10;&#10;no seller_accounts row&#10;sell flow + settings offer&#10;&quot;set up payouts&quot; (D33)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f1ee;strokeColor=#57524b;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="started" value="started&#10;&#10;Express account created&#10;(country = seller's, transfers&#10;capability requested);&#10;Account Link issued" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7f3ea;strokeColor=#26221c;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="180" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="active" value="active&#10;&#10;transfers_enabled = true&#10;the ONLY state that gates open:&#10;listing opt-in + order creation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#047857;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="180" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="restricted" value="restricted&#10;&#10;disabled_reason set,&#10;transfers_enabled = false&#10;(periodic KYC re-checks can&#10;trigger this AFTER onboarding)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="900" y="440" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="o1" value="clicks &quot;set up payouts&quot;&#10;(repeat clicks reuse the stored&#10;account id - one account, ever)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#26221c;fontSize=11;verticalAlign=bottom;" edge="1" parent="1" source="none" target="started">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="o2" value="completes Stripe forms -&gt;&#10;account.updated: transfers active" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;verticalAlign=bottom;" edge="1" parent="1" source="started" target="active">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="o3" value="requirements&#10;past due" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b45309;fontSize=11;exitX=0.15;exitY=1;entryX=0.15;entryY=0;align=right;" edge="1" parent="1" source="active" target="restricted">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="o4" value="cured via fresh&#10;link (settings)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;exitX=0.85;exitY=0;entryX=0.85;entryY=1;align=left;" edge="1" parent="1" source="restricted" target="active">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="o5" value="abandoned forms stay here - settings re-issues the (single-use, short-lived) Account Link on demand" style="text;html=1;fontSize=11;fontColor=#57524b;align=left;" vertex="1" parent="1">
          <mxGeometry x="480" y="300" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="gates" value="What 'active' opens&#10;&#10;- listing form shows the &quot;enable secure payment&quot; opt-in (listings.payment_enabled)&#10;- checkout creates orders for that seller's platform_sale listings&#10;- release-time Transfers succeed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#047857;fontSize=11;align=left;spacing=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1280" y="180" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="inflight" value="Restricted with money in flight&#10;&#10;- new orders refused at creation (guard re-checks)&#10;- pending PaymentIntents may still succeed -&gt; paid_held (buyer-safe: funds held on the platform balance)&#10;- release Transfers fail -&gt; D32 reconciler retries + alerts; admin waits for the cure or refunds the buyer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b45309;fontSize=11;align=left;spacing=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1280" y="440" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="webhook" value="account.updated arrives on the CONNECT webhook endpoint (separate signing secret from account webhooks); upserts seller_accounts - idempotent by construction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e2f7;strokeColor=#5b21b6;fontSize=11;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="470" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gdpr" value="GDPR: on account deletion the seller_accounts row is deleted once no non-terminal orders remain; order rows keep the 10-year anonymized carve-out; the Stripe account belongs to the seller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f1ee;strokeColor=#57524b;fontSize=11;align=left;spacing=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="360" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
