        <mxCell id="tunnel" value="cloudflared&#10;(outbound tunnel - no inbound ports)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#b45309;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="370" width="170" height="80" as="geometry" />
