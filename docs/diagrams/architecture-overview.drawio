        <mxCell id="stripe" value="Stripe Connect&#10;PaymentIntents - held funds - Transfers&#10;Express onboarding (KYC stays at Stripe)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e2f7;strokeColor=#5b21b6;fontSize=12;" vertex="1" parent="1">
