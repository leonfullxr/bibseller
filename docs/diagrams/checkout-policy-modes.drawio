        <mxCell id="m4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="race" target="unk">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;" edge="1" parent="1" source="ps" target="sellerQ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;exitX=1;exitY=0.35;entryX=0;entryY=0.5;" edge="1" parent="1" source="sellerQ" target="psYes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;fontSize=11;exitX=1;exitY=0.65;entryX=0;entryY=0.5;" edge="1" parent="1" source="sellerQ" target="psNo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0369a1;" edge="1" parent="1" source="oo" target="ooOut">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b45309;" edge="1" parent="1" source="co" target="ackOut">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;exitX=1;exitY=0.5;entryX=0.25;entryY=1;" edge="1" parent="1" source="unk" target="ackOut">
          <mxGeometry relative="1" as="geometry" />
