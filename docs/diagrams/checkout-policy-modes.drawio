<mxfile host="app.diagrams.net" agent="bibseller-docs" version="24.7.8">
  <diagram id="modes" name="Checkout by policy mode">
    <mxGraphModel dx="1700" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="What a buyer can do, by transfer_policy - the safety architecture in one picture" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#26221c;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Enforced server-side and by DB constraints, never only in UI. Buyer bar for chat AND checkout: signed-in + email-verified. No guest checkout (evidence trail + DAC7 totals bind to accounts)." style="text;html=1;fontSize=12;fontColor=#79736b;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="race" value="race.transfer_policy" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f7f3ea;strokeColor=#26221c;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ps" value="platform_sale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#047857;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="160" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sellerQ" value="seller active&#10;(seller_accounts) +&#10;listing opt-in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#047857;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="760" y="130" width="190" height="120" as="geometry" />
        </mxCell>
        <mxCell id="psYes" value="Buy securely - Stripe.js checkout&#10;&#10;itemized fee line + &quot;non-refundable&quot; disclosure (D31)&#10;funds held until the transfer is confirmed&#10;chat available alongside" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#047857;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="90" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="psNo" value="Message seller (primary)&#10;&#10;quiet nudge: &quot;secure payment available if the seller enables it&quot; -&#10;never blocks chat, never shames the seller (payments are optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#047857;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="220" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="oo" value="official_only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="400" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ooOut" value="Official process link (race's own name-change procedure)&#10;&#10;no payment UI - structurally: no code path builds a PaymentIntent here.&#10;official_transfer_url is DB-enforced for this mode. Chat available." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0369a1;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="370" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="co" value="connect_only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="540" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="unk" value="unknown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7e4df;strokeColor=#57524b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="660" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ackOut" value="Message seller (primary) - AFTER a recorded acknowledgment&#10;&#10;strong disclaimer + policy_acks row before first contact (D10);&#10;no payment UI, structurally. The platform provides the channel and&#10;takes no part in money or transfer - the strongest liability posture." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b45309;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="540" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="m1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="race" target="ps">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0369a1;" edge="1" parent="1" source="race" target="oo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b45309;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="race" target="co">
          <mxGeometry relative="1" as="geometry" />
