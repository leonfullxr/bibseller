<mxfile host="app.diagrams.net" agent="bibseller-docs" version="24.7.8">
  <diagram id="order-sm" name="Order state machine">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Order state machine (platform_sale only) - every transition appends order_events in the same transaction" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#26221c;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="green = money released to seller - grey = money returned / never taken - amber = frozen for manual resolution.&#10;Transitions are guarded updates (UPDATE ... SET state=$to WHERE id=$1 AND state=$from): replays and races cannot double-fire.&#10;paid -&gt; held happens on the signed payment_intent.succeeded webhook, amount-verified and idempotent via stripe_events." style="text;html=1;fontSize=12;fontColor=#79736b;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="start" value="" style="ellipse;fillColor=#26221c;strokeColor=#26221c;" vertex="1" parent="1">
          <mxGeometry x="50" y="328" width="24" height="24" as="geometry" />
        </mxCell>
        <mxCell id="pending" value="pending_payment&#10;&#10;listing reserved (30 min TTL)&#10;one PaymentIntent, retryable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7f3ea;strokeColor=#26221c;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="130" y="290" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="held" value="paid_held&#10;&#10;funds on the platform balance&#10;(not paid out to anyone)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf1f2;strokeColor=#93283b;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="590" y="290" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="marked" value="seller_marked_transferred&#10;&#10;3-day confirm/dispute window&#10;(D31)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf1f2;strokeColor=#93283b;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1050" y="290" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="completed" value="completed&#10;&#10;Transfer -&gt; seller&#10;listing -&gt; sold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#047857;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1530" y="290" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="cancelled" value="cancelled&#10;&#10;no money ever taken&#10;listing back to active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7e4df;strokeColor=#57524b;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="130" y="620" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="refunded" value="refunded&#10;&#10;Refund of item amount&#10;(fee non-refundable - D31)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7e4df;strokeColor=#57524b;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="590" y="620" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="disputed" value="disputed&#10;&#10;auto-release frozen&#10;evidence: order_events + chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1050" y="620" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="t0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#26221c;" edge="1" parent="1" source="start" target="pending">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="payment webhook&#10;(verified + idempotent)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;verticalAlign=bottom;" edge="1" parent="1" source="pending" target="held">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="TTL / buyer abort&#10;(PI cancelled at Stripe FIRST -&#10;kills the late-success race)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="pending" target="cancelled">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="seller marks&#10;bib transferred" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#93283b;fontSize=11;verticalAlign=bottom;" edge="1" parent="1" source="held" target="marked">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="either party cancels /&#10;race date passes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="held" target="refunded">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="buyer confirms OR&#10;auto-release after 3 days&#10;-&gt; Transfer (transfer:{order_id})" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;verticalAlign=bottom;" edge="1" parent="1" source="marked" target="completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t6" value="buyer reports&#10;a problem" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b45309;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="marked" target="disputed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t7" value="admin: for seller" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#047857;fontSize=11;exitX=0.75;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="disputed" target="completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t8" value="admin: for buyer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#57524b;fontSize=11;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="disputed" target="refunded">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="Chargebacks: while held -&gt; charge.dispute.created maps to disputed (low risk, nothing paid out yet). After release -&gt; transfer reversal attempt + ToS clause; the processing fee cannot be withheld on chargebacks (Stripe returns the full charge)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=11;align=left;spacing=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1330" y="770" width="400" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
