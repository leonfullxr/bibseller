# Copy to deploy/.env.staging (gitignored) and fill in real values. Loaded by the
# `make staging-*` targets. Staging is the prod compose stack run as a second,
# ephemeral project on the same box (docs/DEPLOYMENT.md), so this mirrors
# .env.prod.example with three deliberate differences: a test PUBLIC_ORIGIN, a
# non-clashing DB_HOST_PORT, and its own Cloudflare Tunnel token.

# Public origin of the staging site (https). Use a single label under your zone
# apex (e.g. bibsellertest.example), NOT test.<app-host>: Cloudflare free
# Universal SSL covers apex + *.apex only, so a two-label host has no edge cert
# and fails the TLS handshake.
PUBLIC_ORIGIN=https://bibsellertest.example

# Host port for the staging Postgres so it does not clash with prod's 5432 on the
# same machine. Only the DB publishes a host port; the rest is internal.
DB_HOST_PORT=5433

# Postgres. Volumes are project-namespaced and separate from prod, so these may
# match prod or differ - staging data is throwaway.
POSTGRES_USER=bibseller
POSTGRES_PASSWORD=replace-with-a-long-random-string
POSTGRES_DB=bibseller

# Object storage (staging's own MinIO volume).
S3_ACCESS_KEY=replace-with-a-random-key
S3_SECRET_KEY=replace-with-a-long-random-secret
S3_BUCKET=bibseller

# Transactional email. Safe to reuse the prod relay; mail still sends for real,
# so test with addresses you control.
EMAIL_FROM=Bibseller staging <noreply@bibseller.example>
MAIL_SENDER_DOMAIN=bibseller.example
MAIL_RELAYHOST=[smtp-relay.brevo.com]:587
MAIL_RELAYHOST_USERNAME=replace-with-relay-user
MAIL_RELAYHOST_PASSWORD=replace-with-relay-key

# A SECOND Cloudflare Tunnel, separate from prod's: Zero Trust -> Networks ->
# Tunnels -> create -> copy the token. Point its public hostname (the
# single-label host above) at http://caddy:80.
TUNNEL_TOKEN=replace-with-staging-cloudflare-tunnel-token
