# Copy to deploy/.env.prod (gitignored) and fill in real values. Loaded by the
# `make prod-*` targets via `docker compose --env-file deploy/.env.prod`.

# Public origin (https - Cloudflare terminates TLS). Drives adapter-node ORIGIN
# (CSRF + url.origin) and the API's APP_URL (verification / reset links).
PUBLIC_ORIGIN=https://bibseller.example

# Postgres
POSTGRES_USER=bibseller
POSTGRES_PASSWORD=replace-with-a-long-random-string
POSTGRES_DB=bibseller

# Object storage. In self-host the MinIO root credentials are the app's S3
# credentials. To use R2 / Scaleway instead, point the api's S3_ENDPOINT there.
S3_ACCESS_KEY=replace-with-a-random-key
S3_SECRET_KEY=replace-with-a-long-random-secret
S3_BUCKET=bibseller

# Transactional email. Postfix relays through this smarthost (e.g. Brevo, SES).
# Set SPF, DKIM and DMARC on the sender domain (the smarthost gives the values).
EMAIL_FROM=Bibseller <noreply@bibseller.example>
MAIL_SENDER_DOMAIN=bibseller.example
MAIL_RELAYHOST=[smtp-relay.brevo.com]:587
MAIL_RELAYHOST_USERNAME=replace-with-relay-user
MAIL_RELAYHOST_PASSWORD=replace-with-relay-key

# Cloudflare Tunnel token: Zero Trust -> Networks -> Tunnels -> create -> copy
# the token. Point the tunnel's public hostname at http://caddy:80.
TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
