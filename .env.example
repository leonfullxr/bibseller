# Copy to .env if you need overrides — every value below matches the
# docker-compose defaults, so dev works with no .env at all.

ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:dev@localhost:5432/bibseller?sslmode=disable

# Frontend server-side → API base URL (browser uses relative /api via proxy)
API_URL=http://localhost:8080

# Object storage (used from M4) — MinIO console: http://localhost:9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bibseller-dev

# SMTP (used from M3) — Mailpit UI: http://localhost:8025
SMTP_ADDR=localhost:1025
